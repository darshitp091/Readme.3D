# Gemini API Key
GEMINI_API_KEY=your_gemini_api_key_here

# Adsterra Configuration
# IMPORTANT: The VITE_ prefix is MANDATORY for these to work in the browser.
# In your website dashboard, ensure the variable names match exactly.
ADSTERRA_API_KEY=your_adsterra_api_key_here
VITE_ADSTERRA_POPUNDER_URL=your_popunder_script_url_here
VITE_ADSTERRA_SOCIALBAR_URL=your_socialbar_script_url_here
